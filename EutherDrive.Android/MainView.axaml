<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:zuul="clr-namespace:EutherDrive.Android.Zuul"
             x:Class="EutherDrive.Android.MainView">
  <UserControl.Styles>
    <Style Selector="Border.surface">
      <Setter Property="Background" Value="#C8141C27" />
      <Setter Property="BorderBrush" Value="#324356" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="22" />
    </Style>

    <Style Selector="Button.chrome">
      <Setter Property="Background" Value="#182736" />
      <Setter Property="Foreground" Value="#EEF6FF" />
      <Setter Property="BorderBrush" Value="#36506B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.chrome:pressed">
      <Setter Property="Background" Value="#0F1B27" />
    </Style>

    <Style Selector="Button.action">
      <Setter Property="Background" Value="#173E43" />
      <Setter Property="BorderBrush" Value="#5EEAD4" />
    </Style>

    <Style Selector="Button.warn">
      <Setter Property="Background" Value="#3A2318" />
      <Setter Property="BorderBrush" Value="#F59E0B" />
    </Style>

    <Style Selector="Button.landscapeOverlay">
      <Setter Property="Background" Value="#8C142534" />
      <Setter Property="Foreground" Value="#EEF6FF" />
      <Setter Property="BorderBrush" Value="#5C7895" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.landscapeOverlay:pressed">
      <Setter Property="Background" Value="#CC173E43" />
      <Setter Property="BorderBrush" Value="#5EEAD4" />
    </Style>

    <Style Selector="Border.touchOverlay">
      <Setter Property="Background" Value="#8C142534" />
      <Setter Property="BorderBrush" Value="#5C7895" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="Border.touchOverlay.padPressed">
      <Setter Property="Background" Value="#CC173E43" />
      <Setter Property="BorderBrush" Value="#5EEAD4" />
    </Style>

    <Style Selector="Border.landscapePad">
      <Setter Property="Background" Value="#8C111B25" />
      <Setter Property="BorderBrush" Value="#59718B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="56" />
    </Style>

    <Style Selector="Border.pad">
      <Setter Property="Width" Value="64" />
      <Setter Property="Height" Value="64" />
      <Setter Property="CornerRadius" Value="32" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#3F566F" />
      <Setter Property="Background" Value="#B8141F2A" />
    </Style>

    <Style Selector="Border.padPressed">
      <Setter Property="Background" Value="#D0183350" />
      <Setter Property="BorderBrush" Value="#7DD3FC" />
    </Style>

    <Style Selector="Border.padGlow">
      <Setter Property="Width" Value="48" />
      <Setter Property="Height" Value="48" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Background" Value="#6B2563EB" />
      <Setter Property="BorderBrush" Value="#93C5FD" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Opacity" Value="0.92" />
      <Setter Property="IsVisible" Value="False" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style Selector="Border.faceGlow">
      <Setter Property="Width" Value="54" />
      <Setter Property="Height" Value="54" />
      <Setter Property="CornerRadius" Value="27" />
      <Setter Property="Background" Value="#542563EB" />
      <Setter Property="BorderBrush" Value="#93C5FD" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Opacity" Value="0.9" />
      <Setter Property="IsVisible" Value="False" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style Selector="Button.facePressed">
      <Setter Property="Background" Value="#C6173E43" />
      <Setter Property="BorderBrush" Value="#7DD3FC" />
    </Style>

    <Style Selector="TextBlock.hudLabel">
      <Setter Property="Foreground" Value="#91A8BD" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="CheckBox.settingsToggle">
      <Setter Property="Foreground" Value="#EEF6FF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <Style Selector="Border.debugShell">
      <Setter Property="Background" Value="#E1070D13" />
      <Setter Property="BorderBrush" Value="#4B6A7E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="24" />
    </Style>

    <Style Selector="Border.debugGlass">
      <Setter Property="Background" Value="#CC0C141C" />
      <Setter Property="BorderBrush" Value="#2C4253" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style Selector="TextBlock.debugEyebrow">
      <Setter Property="Foreground" Value="#5EEAD4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.debugTitle">
      <Setter Property="Foreground" Value="#EEF6FF" />
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="FontStyle" Value="Italic" />
    </Style>
  </UserControl.Styles>

  <Grid Background="#091119">
    <Border Margin="-120,-70,0,0"
            Width="340"
            Height="340"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            CornerRadius="170"
            Background="#173149"
            Opacity="0.24" />
    <Border Margin="0,180,-120,0"
            Width="300"
            Height="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            CornerRadius="150"
            Background="#2A1A29"
            Opacity="0.18" />

    <Grid RowDefinitions="Auto,*,Auto" Margin="{Binding RootMargin}" RowSpacing="{Binding RootRowSpacing}">
      <Border Grid.Row="0" Classes="surface" Padding="14" IsVisible="{Binding IsPortraitMode}">
        <Grid ColumnDefinitions="*" RowDefinitions="Auto">
          <Grid IsVisible="{Binding NormalTopButtonsVisible}"
                ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                ColumnSpacing="6">
            <Button Grid.Column="0"
                    Classes="chrome"
                    Padding="12,10"
                    Content="Settings"
                    Click="OnMenuTapped" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="EutherDrive Android"
                         FontSize="24"
                         FontWeight="Black"
                         FontStyle="Italic"
                         Foreground="#EEF6FF" />
            </StackPanel>

            <Button Grid.Column="2"
                    Classes="chrome"
                    Padding="12,10"
                    Content="ROM"
                    Click="OnPickRom" />
            <Button Grid.Column="3"
                    Classes="chrome"
                    Width="42"
                    Padding="0,10"
                    Content="D"
                    Click="OnOpenDebug" />
            <Button Grid.Column="4"
                    Classes="chrome action"
                    Padding="12,10"
                    Content="Start"
                    Click="OnStartClicked" />
            <Button Grid.Column="5"
                    Classes="chrome warn"
                    Padding="12,10"
                    Content="Stop"
                    Click="OnStopClicked" />
          </Grid>

          <Grid IsVisible="{Binding QuickSaveButtonsVisible}"
                ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                ColumnSpacing="8">
            <Button Grid.Column="0"
                    Classes="chrome"
                    Content="Sav1"
                    IsEnabled="{Binding IsRunning}"
                    Click="OnSaveSlot1" />
            <Button Grid.Column="1"
                    Classes="chrome"
                    Content="Load1"
                    IsEnabled="{Binding IsRunning}"
                    Click="OnLoadSlot1" />

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Text="Focus Mode"
                       FontSize="22"
                       FontWeight="Black"
                       FontStyle="Italic"
                       Foreground="#EEF6FF" />

            <Button Grid.Column="3"
                    Classes="chrome"
                    Content="Sav2"
                    IsEnabled="{Binding IsRunning}"
                    Click="OnSaveSlot2" />
            <Button Grid.Column="4"
                    Classes="chrome"
                    Content="Load2"
                    IsEnabled="{Binding IsRunning}"
                    Click="OnLoadSlot2" />
          </Grid>
        </Grid>
      </Border>

      <Grid Grid.Row="1" IsVisible="{Binding IsPortraitMode}" RowDefinitions="*,Auto" RowSpacing="12">
        <Border Grid.Row="0" Classes="surface" Padding="{Binding ScreenSurfacePadding}">
          <Grid>
            <Border CornerRadius="18"
                    Background="#060A0E"
                    BorderBrush="#3A4A59"
                    BorderThickness="1" />

            <Grid Margin="{Binding ScreenFrameMargin}">
              <Border HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      CornerRadius="16"
                      Background="#0D131A" />

              <Grid Margin="{Binding ScreenContentMargin}" RowDefinitions="Auto,*,Auto,Auto">
                <Grid IsVisible="{Binding ScreenHudVisible}">
                  <Border HorizontalAlignment="Left"
                          Background="#A0121923"
                          CornerRadius="999"
                          Padding="10,6">
                    <TextBlock Text="{Binding StatusPill}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#5EEAD4" />
                  </Border>

                  <Border HorizontalAlignment="Center"
                          Background="#A0121923"
                          CornerRadius="999"
                          Padding="10,6">
                    <TextBlock Text="{Binding PerfHeadline}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#93C5FD" />
                  </Border>

                  <Border HorizontalAlignment="Right"
                          Background="#A0121923"
                          CornerRadius="999"
                          Padding="10,6">
                    <TextBlock Text="{Binding SelectedConsoleLabel}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#F59E0B" />
                  </Border>
                </Grid>

                <Grid Grid.Row="1"
                      PointerPressed="OnToggleScreenFocus">
                  <Viewbox Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch">
                    <Grid x:Name="PortraitScreenHost">
                      <Image Name="PortraitScreenImage"
                             Stretch="Fill"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch" />
                    </Grid>
                  </Viewbox>

                  <Border HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          MaxWidth="360"
                          Padding="18"
                          CornerRadius="18"
                          Background="#A00B1219"
                          IsVisible="{Binding ScreenOverlayVisible}">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{Binding ScreenTitle}"
                                 FontSize="28"
                                 FontWeight="Black"
                                 TextAlignment="Center"
                                 Foreground="#EEF6FF" />
                      <TextBlock Text="{Binding ScreenDescription}"
                                 FontSize="14"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 Foreground="#91A8BD" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Grid.Row="2"
                        IsVisible="{Binding ScreenHudVisible}"
                        HorizontalAlignment="Stretch"
                        Background="#7A101820"
                        CornerRadius="16"
                        Padding="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="hudLabel" Text="Current ROM" />
                      <TextBlock Text="{Binding CurrentRomDisplay}"
                                 Foreground="#EEF6FF"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                      <TextBlock Classes="hudLabel" Text="Input" />
                      <TextBlock Text="{Binding LastPressedDisplay}"
                                 Foreground="#FB7185"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Right" />
                    </StackPanel>
                  </Grid>
                </Border>

              </Grid>
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="1" Classes="surface" Padding="14">
          <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="18">
            <Grid x:Name="PortraitDPadSurface"
                  Grid.Column="0"
                  Width="192"
                  Height="192"
                  HorizontalAlignment="Center"
                  Background="Transparent"
                  PointerPressed="OnDPadPointerPressed"
                  PointerMoved="OnDPadPointerMoved"
                  PointerReleased="OnDPadPointerReleased"
                  PointerCaptureLost="OnDPadPointerCaptureLost">
              <Canvas IsHitTestVisible="False">
                <Border x:Name="PortraitPadGlow"
                        Classes="padGlow" />
              </Canvas>
              <Border x:Name="PortraitPadUp"
                      Classes="pad"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top">
                <TextBlock Text="▲" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" />
              </Border>
              <Border x:Name="PortraitPadDown"
                      Classes="pad"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom">
                <TextBlock Text="▼" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" />
              </Border>
              <Border x:Name="PortraitPadLeft"
                      Classes="pad"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center">
                <TextBlock Text="◀" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" />
              </Border>
              <Border x:Name="PortraitPadRight"
                      Classes="pad"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
                <TextBlock Text="▶" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" />
              </Border>
              <Border Width="62"
                      Height="62"
                      IsHitTestVisible="False"
                      CornerRadius="31"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="#C80D141B"
                      BorderBrush="#43566A"
                      BorderThickness="1">
                <TextBlock Text="D-Pad"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#91A8BD" />
              </Border>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
              <Border Classes="touchOverlay"
                      Width="74"
                      PointerPressed="OnOverlayButtonPress"
                      PointerReleased="OnOverlayButtonRelease"
                      PointerCaptureLost="OnOverlayButtonCaptureLost"
                      Tag="Menu">
                <TextBlock Text="Menu"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#EEF6FF" />
              </Border>
              <Border Classes="touchOverlay"
                      Width="74"
                      PointerPressed="OnOverlayButtonPress"
                      PointerReleased="OnOverlayButtonRelease"
                      PointerCaptureLost="OnOverlayButtonCaptureLost"
                      Tag="Select">
                <TextBlock Text="Select"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#EEF6FF" />
              </Border>
              <Border Classes="touchOverlay"
                      Width="74"
                      PointerPressed="OnOverlayButtonPress"
                      PointerReleased="OnOverlayButtonRelease"
                      PointerCaptureLost="OnOverlayButtonCaptureLost"
                      Tag="Start">
                <TextBlock Text="Start"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#EEF6FF" />
              </Border>
            </StackPanel>

            <Grid x:Name="PortraitFaceSurface"
                  Grid.Column="2"
                  Width="212"
                  Height="212"
                  HorizontalAlignment="Center"
                  Background="Transparent"
                  PointerPressed="OnFacePointerPressed"
                  PointerMoved="OnFacePointerMoved"
                  PointerReleased="OnFacePointerReleased"
                  PointerCaptureLost="OnFacePointerCaptureLost">
              <Canvas IsHitTestVisible="False">
                <Border x:Name="PortraitFaceGlow"
                        Classes="faceGlow" />
              </Canvas>
              <Button x:Name="PortraitFaceY"
                      Classes="chrome action"
                      Width="74"
                      Height="74"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Content="Y" />
              <Button x:Name="PortraitFaceB"
                      Classes="chrome action"
                      Width="74"
                      Height="74"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      Content="B" />
              <Button x:Name="PortraitFaceX"
                      Classes="chrome action"
                      Width="74"
                      Height="74"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Content="X" />
              <Button x:Name="PortraitFaceA"
                      Classes="chrome action"
                      Width="74"
                      Height="74"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Content="A" />
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="1"
            IsVisible="{Binding IsLandscapeMode}">
        <Grid Margin="-6,0,-6,0">
          <Viewbox Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   PointerPressed="OnToggleScreenFocus">
            <Grid x:Name="LandscapeScreenHost">
              <Image Name="LandscapeScreenImage"
                     Stretch="Fill"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch" />
            </Grid>
          </Viewbox>

          <Border IsVisible="{Binding ScreenOverlayVisible}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  MaxWidth="420"
                  Padding="18"
                  CornerRadius="18"
                  Background="#A00B1219">
            <StackPanel Spacing="10">
              <TextBlock Text="{Binding ScreenTitle}"
                         FontSize="28"
                         FontWeight="Black"
                         TextAlignment="Center"
                         Foreground="#EEF6FF" />
              <TextBlock Text="{Binding ScreenDescription}"
                         FontSize="14"
                         TextWrapping="Wrap"
                         TextAlignment="Center"
                         Foreground="#91A8BD" />
            </StackPanel>
          </Border>

          <Grid HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="22,14,0,0"
                RowDefinitions="Auto,Auto,Auto"
                ColumnDefinitions="Auto,Auto"
                ColumnSpacing="8"
                RowSpacing="8">
            <TextBlock Grid.ColumnSpan="2"
                       IsVisible="{Binding ScreenHudVisible}"
                       Text="{Binding StatusPill}"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="#5EEAD4"
                       Margin="6,0,0,2" />
            <Border Grid.Row="1"
                    Classes="touchOverlay"
                    Width="58"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="L2">
              <TextBlock Text="L2"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="touchOverlay"
                    Width="72"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="Select">
              <TextBlock Text="Select"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
            <Border Grid.Row="2"
                    Classes="touchOverlay"
                    Width="58"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="L1">
              <TextBlock Text="L1"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
            <Border Grid.Row="2"
                    Grid.Column="1"
                    Classes="touchOverlay"
                    Width="72"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="Start">
              <TextBlock Text="Start"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
          </Grid>

          <Grid HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,22,0"
                RowDefinitions="Auto,Auto,Auto"
                ColumnDefinitions="Auto,Auto"
                ColumnSpacing="8"
                RowSpacing="8">
            <TextBlock Grid.ColumnSpan="2"
                       IsVisible="{Binding ScreenHudVisible}"
                       Text="{Binding SelectedConsoleLabel}"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="#F59E0B"
                       HorizontalAlignment="Right"
                       Margin="0,0,6,2" />
            <Border Grid.Row="1"
                    Classes="touchOverlay"
                    Width="72"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="Menu">
              <TextBlock Text="Menu"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="touchOverlay"
                    Width="58"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="R2">
              <TextBlock Text="R2"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
            <Border Grid.Row="2"
                    Background="Transparent" />
            <Border Grid.Row="2"
                    Grid.Column="1"
                    Classes="touchOverlay"
                    Width="58"
                    PointerPressed="OnOverlayButtonPress"
                    PointerReleased="OnOverlayButtonRelease"
                    PointerCaptureLost="OnOverlayButtonCaptureLost"
                    Tag="R1">
              <TextBlock Text="R1"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#EEF6FF" />
            </Border>
          </Grid>

          <Grid x:Name="LandscapeDPadSurface"
                Width="150"
                Height="150"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="26,0,0,18"
                Background="Transparent"
                PointerPressed="OnDPadPointerPressed"
                PointerMoved="OnDPadPointerMoved"
                PointerReleased="OnDPadPointerReleased"
                PointerCaptureLost="OnDPadPointerCaptureLost">
            <Canvas IsHitTestVisible="False">
              <Border x:Name="LandscapePadGlow"
                      Classes="padGlow" />
            </Canvas>
            <Border x:Name="LandscapePadUp"
                    Classes="landscapePad"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
              <TextBlock Text="▲" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
            </Border>
            <Border x:Name="LandscapePadDown"
                    Classes="landscapePad"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">
              <TextBlock Text="▼" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
            </Border>
            <Border x:Name="LandscapePadLeft"
                    Classes="landscapePad"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
              <TextBlock Text="◀" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
            </Border>
            <Border x:Name="LandscapePadRight"
                    Classes="landscapePad"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
              <TextBlock Text="▶" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
            </Border>
          </Grid>

          <Grid x:Name="LandscapeFaceSurface"
                Width="192"
                Height="192"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,22,18"
                Background="Transparent"
                PointerPressed="OnFacePointerPressed"
                PointerMoved="OnFacePointerMoved"
                PointerReleased="OnFacePointerReleased"
                PointerCaptureLost="OnFacePointerCaptureLost">
            <Canvas IsHitTestVisible="False">
              <Border x:Name="LandscapeFaceGlow"
                      Classes="faceGlow" />
            </Canvas>
            <Button x:Name="LandscapeFaceY"
                    Classes="landscapeOverlay"
                    Width="68"
                    Height="68"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="Y" />
            <Button x:Name="LandscapeFaceB"
                    Classes="landscapeOverlay"
                    Width="68"
                    Height="68"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Content="B" />
            <Button x:Name="LandscapeFaceX"
                    Classes="landscapeOverlay"
                    Width="68"
                    Height="68"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Content="X" />
            <Button x:Name="LandscapeFaceA"
                    Classes="landscapeOverlay"
                    Width="68"
                    Height="68"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Content="A" />
          </Grid>

        </Grid>
      </Grid>

      <Border Grid.Row="2" Classes="surface" Padding="12" IsVisible="{Binding IsPortraitMode}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
          <StackPanel Spacing="4">
            <TextBlock Classes="hudLabel" Text="Session" />
            <TextBlock Text="{Binding FooterStatus}" Foreground="#EEF6FF" TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Right">
            <TextBlock Classes="hudLabel" Text="Overlay" HorizontalAlignment="Right" />
            <TextBlock Text="{Binding OverlaySummary}"
                       HorizontalAlignment="Right"
                       Foreground="#5EEAD4" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Border IsVisible="{Binding SettingsVisible}"
            Background="#CC091119">
      <Grid Margin="18">
        <Border Classes="surface"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                MaxWidth="720"
                Padding="18">
          <Grid RowDefinitions="Auto,*" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel Spacing="4">
                <TextBlock Text="System Files"
                           FontSize="22"
                           FontWeight="Black"
                           FontStyle="Italic" />
                <TextBlock Text="Pick BIOS and coprocessor files once and keep them in app storage."
                           Foreground="#91A8BD"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="chrome"
                      Content="Close"
                      Click="OnCloseSettings" />
            </Grid>

            <ScrollViewer Grid.Row="1" MaxHeight="520">
              <StackPanel Spacing="12">
                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="PCE BIOS" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding PceBiosDisplay}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickPceBios" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearPceBios" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="SEGA CD BIOS" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding SegaCdBiosDisplay}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickSegaCdBios" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearSegaCdBios" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="PSX BIOS" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding PsxBiosDisplay}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickPsxBios" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearPsxBios" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="PSX Boot"
                               FontWeight="Bold" />
                    <CheckBox Classes="settingsToggle"
                              Content="PSX fast load"
                              IsChecked="{Binding PsxFastLoadEnabled}"
                              Click="OnPsxFastLoadToggle" />
                    <CheckBox Classes="settingsToggle"
                              Content="PSX superfast boot"
                              IsChecked="{Binding PsxSuperFastBootEnabled}"
                              Click="OnPsxSuperFastBootToggle" />
                    <TextBlock Text="Fast load trims normal boot waits. Superfast boot is more aggressive and usually matters on next boot."
                               Foreground="#91A8BD"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="DSP1" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Dsp1Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickDsp1" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearDsp1" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="DSP2" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Dsp2Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickDsp2" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearDsp2" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="DSP3" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Dsp3Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickDsp3" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearDsp3" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="DSP4" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Dsp4Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickDsp4" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearDsp4" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="ST010" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding St010Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickSt010" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearSt010" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="ST011" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding St011Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickSt011" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearSt011" />
                  </Grid>
                </Border>

                <Border Classes="surface" Padding="12">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="ST018" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding St018Display}" Foreground="#91A8BD" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="chrome" Content="Pick" Click="OnPickSt018" />
                    <Button Grid.Column="3" Classes="chrome" Content="Clear" Click="OnClearSt018" />
                  </Grid>
                </Border>

                <TextBlock Text="{Binding SettingsHint}"
                           Foreground="#91A8BD"
                           TextWrapping="Wrap" />

                <Border Classes="surface" Padding="14">
                  <StackPanel Spacing="10">
                    <StackPanel Spacing="3">
                      <TextBlock Text="About"
                                 FontSize="22"
                                 FontWeight="Black"
                                 FontStyle="Italic"
                                 Foreground="#EEF6FF" />
                      <TextBlock Text="Desktop About-rutan ligger nu fast längst ner här också."
                                 Foreground="#91A8BD"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Background="#05080C"
                            BorderBrush="#5E2A2A"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="10">
                      <zuul:ZuulView x:Name="SettingsAboutZuulView"
                                     Height="220"
                                     HorizontalAlignment="Stretch" />
                    </Border>

                    <TextBlock Text="Made by Nichlas and AI"
                               HorizontalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#EEF6FF" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border IsVisible="{Binding DebugVisible}"
            Background="#DE050B10"
            PointerPressed="OnCloseDebug">
      <Grid Margin="18">
        <Border Classes="debugShell"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Padding="20"
                IsHitTestVisible="False">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center">
                <Border Width="10"
                        Height="10"
                        CornerRadius="5"
                        Background="#5EEAD4" />
                <Border Width="10"
                        Height="10"
                        CornerRadius="5"
                        Background="#F59E0B" />
                <Border Width="10"
                        Height="10"
                        CornerRadius="5"
                        Background="#FB7185" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Spacing="2">
                <TextBlock Classes="debugEyebrow"
                           Text="ANDROID RUNTIME TRACE" />
                <TextBlock Classes="debugTitle"
                           Text="EutherDrive Debug View" />
              </StackPanel>

              <Border Grid.Column="2"
                      Background="#8A121C25"
                      BorderBrush="#32485A"
                      BorderThickness="1"
                      CornerRadius="999"
                      Padding="12,8">
                <TextBlock Text="Tap Anywhere To Close"
                           Foreground="#91A8BD"
                           FontSize="11"
                           FontWeight="SemiBold" />
              </Border>
            </Grid>

            <Border Grid.Row="1"
                    Classes="debugGlass"
                    Padding="12">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                    ColumnSpacing="8">
                <TextBlock Text="Live PSX/Android instrumentation snapshot"
                           Foreground="#D6E3F0"
                           FontWeight="SemiBold" />
                <Border Grid.Column="1"
                        Background="#162735"
                        CornerRadius="999"
                        Padding="10,5">
                  <TextBlock Text="CORE"
                             Foreground="#5EEAD4"
                             FontSize="11"
                             FontWeight="Bold" />
                </Border>
                <Border Grid.Column="2"
                        Background="#2A2013"
                        CornerRadius="999"
                        Padding="10,5">
                  <TextBlock Text="BOOT"
                             Foreground="#F59E0B"
                             FontSize="11"
                             FontWeight="Bold" />
                </Border>
                <Border Grid.Column="3"
                        Background="#23131E"
                        CornerRadius="999"
                        Padding="10,5">
                  <TextBlock Text="DMA / CD"
                             Foreground="#FB7185"
                             FontSize="11"
                             FontWeight="Bold" />
                </Border>
              </Grid>
            </Border>

            <Grid Grid.Row="2">
              <Border Classes="debugGlass"
                      Margin="0,0,0,10" />
              <Border Classes="debugGlass"
                      Margin="10,10,0,0"
                      Opacity="0.22" />
              <Border Classes="debugGlass"
                      Padding="14">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10">
                  <Border Background="#8A071017"
                          CornerRadius="10"
                          Padding="10,6">
                    <TextBlock Text="Frame Trace"
                               Foreground="#91A8BD"
                               FontSize="11"
                               FontWeight="Bold" />
                  </Border>

                  <Border Grid.Row="1"
                          Background="#D204090D"
                          BorderBrush="#1E3949"
                          BorderThickness="1"
                          CornerRadius="14"
                          Padding="12">
                    <TextBox Text="{Binding PerfSummary}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontSize="12"
                             FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                             Foreground="#D8E7F5"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             IsHitTestVisible="False" />
                  </Border>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
