<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:imaging="clr-namespace:Avalonia.Media.Imaging;assembly=Avalonia"
        xmlns:savestates="clr-namespace:EutherDrive.UI.Savestates"
        mc:Ignorable="d"
        x:Class="EutherDrive.UI.MainWindow">
  <Grid>
    <Border Background="{StaticResource EdBgBrush}"/>
    <Border Margin="-160,-120,0,0"
            Width="520"
            Height="520"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            CornerRadius="260"
            Background="#182A3D"
            Opacity="0.18"/>
    <Border Margin="0,120,-180,0"
            Width="460"
            Height="460"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            CornerRadius="230"
            Background="#2A1B24"
            Opacity="0.16"/>

    <Grid Name="RootGrid" RowDefinitions="Auto,*" ColumnDefinitions="Auto,*" Margin="12" RowSpacing="12" ColumnSpacing="12">

      <LayoutTransformControl Name="TopControlsScaler" Grid.Row="0" Grid.ColumnSpan="2">
        <Border Classes="panel" Padding="6">
          <StackPanel Name="TopControlsPanel" Orientation="Horizontal" Spacing="6">
          <Button Classes="action compact" Content="Open ROM…" Click="OnOpenRom"/>
          <Border Classes="panel" Padding="6,5">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Classes="kicker" Text="Recent"/>
              <ComboBox Name="RecentRomCombo" Width="180" SelectionChanged="OnRecentRomSelected"/>
            </StackPanel>
          </Border>
          <Border Classes="panel" Padding="8,5">
            <StackPanel Spacing="4">
              <TextBlock Classes="deck-label" Text="RENDERER"/>
              <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" RowSpacing="2">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Name="RenderBackendBitmapLabel"
                           Classes="kicker"
                           Text="Bitmap"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Name="RenderBackendOpenGlLabel"
                           Classes="kicker"
                           Text="OpenGL"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Name="RenderBackendVulkanLabel"
                           Classes="kicker"
                           Text="Vulkan"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
                <Slider Name="RenderBackendSlider"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Minimum="0"
                        Maximum="2"
                        Width="156"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="0"
                        ValueChanged="OnRenderBackendSliderChanged"/>
              </Grid>
              <TextBlock Name="RenderBackendStateText"
                         Classes="kicker"
                         Text="Active: Bitmap"
                         Opacity="0.8"/>
            </StackPanel>
          </Border>
          <StackPanel Spacing="6" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="action compact" Content="Start" Click="OnStart"/>
              <Button Classes="compact" Content="Stop" Click="OnStop"/>
              <Button Classes="ghost compact" Content="About" Click="OnAbout"/>
              <Button Classes="compact" Content="Input Settings" Click="OnInputSettings"/>
            </StackPanel>
            <Expander ExpandDirection="Down" IsExpanded="False" HorizontalAlignment="Left" Width="324">
              <Expander.Header>
                <Border Classes="panel" Padding="10,5">
                  <TextBlock Classes="deck-label" Text="SAVESTATES"/>
                </Border>
              </Expander.Header>
              <Border Name="SavestatePanel" Classes="panel" Padding="6" Margin="0,6,0,0" x:DataType="savestates:SavestateViewModel">
                <StackPanel Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding Slot1Label}" Width="128" FontSize="10" VerticalAlignment="Center"/>
                    <Button Classes="small" Content="Save" Command="{Binding SaveSlot1Command}"/>
                    <Button Classes="small" Content="Load" Command="{Binding LoadSlot1Command}"/>
                    <Button Classes="small ghost" Content="Clear" Command="{Binding ClearSlot1Command}"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding Slot2Label}" Width="128" FontSize="10" VerticalAlignment="Center"/>
                    <Button Classes="small" Content="Save" Command="{Binding SaveSlot2Command}"/>
                    <Button Classes="small" Content="Load" Command="{Binding LoadSlot2Command}"/>
                    <Button Classes="small ghost" Content="Clear" Command="{Binding ClearSlot2Command}"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding Slot3Label}" Width="128" FontSize="10" VerticalAlignment="Center"/>
                    <Button Classes="small" Content="Save" Command="{Binding SaveSlot3Command}"/>
                    <Button Classes="small" Content="Load" Command="{Binding LoadSlot3Command}"/>
                    <Button Classes="small ghost" Content="Clear" Command="{Binding ClearSlot3Command}"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Expander>
          </StackPanel>
          <Border Classes="panel" Padding="6,5">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Classes="deck-label" Text="MASTER VOL"/>
              <Slider Name="MasterVolumeSlider"
                      Minimum="0"
                      Maximum="100"
                      Width="100"
                      Value="50"
                      ValueChanged="OnMasterVolumeChanged"/>
              <TextBlock Name="MasterVolumeValueText" Width="36" Text="50%" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
          <Border Classes="panel" Padding="8,5" MinWidth="300">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0"
                         Classes="deck-label"
                         Text="AUTOFIRE"
                         VerticalAlignment="Top"
                         Margin="0,2,0,0"/>
              <StackPanel Grid.Column="1" Spacing="4">
                <StackPanel Name="AutoFireButtonsPanel" Spacing="4"/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Slider Name="AutoFireRateSlider"
                          Minimum="5"
                          Maximum="30"
                          Width="96"
                          Value="12"
                          ValueChanged="OnAutoFireRateChanged"/>
                  <TextBlock Name="AutoFireRateText" Width="34" Text="12Hz" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </Grid>
          </Border>
          <Border Classes="panel" Padding="6,5">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Classes="kicker" Text="Status"/>
              <TextBox Name="StatusText"
                       Classes="status-inline"
                       IsReadOnly="True"
                       BorderThickness="0"
                       Background="Transparent"
                       TextWrapping="NoWrap"
                       SelectionBrush="#3A7BD5"
                       Width="220"/>
            </StackPanel>
          </Border>
          </StackPanel>
        </Border>
      </LayoutTransformControl>

      <LayoutTransformControl Name="InfoPanelScaler" Grid.Row="1" Grid.Column="0">
        <Border Name="InfoPanel" Classes="panel" Padding="10">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8" Width="240">
            <TextBlock Classes="deck-label" Text="MACHINE ROOM"/>
            <CheckBox Content="Use DummyCore" IsChecked="False" Name="UseDummyCoreCheck"/>
            <CheckBox Content="Use 6-button controller" IsChecked="False" Name="SixButtonPadCheck"/>
            <CheckBox Content="Enable audio" IsChecked="True" Name="AudioEnabledCheck" Checked="OnAudioToggle" Unchecked="OnAudioToggle"/>
            <CheckBox Name="AllowDangerousSportTitlesCheck"
                      Content="Allow dangerous sport titles"
                      IsChecked="False"
                      Checked="OnAllowDangerousSportTitlesToggle"
                      Unchecked="OnAllowDangerousSportTitlesToggle"/>
            <TextBlock Classes="muted"
                       FontSize="12"
                       Margin="18,0,0,0"
                       Text="SportShield blocks suspected sports ROMs unless this override is enabled."/>
            <CheckBox Content="Mouse capture" IsChecked="False" Name="MouseCaptureCheck" Checked="OnMouseCaptureToggle" Unchecked="OnMouseCaptureToggle"/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="18,0,0,0">
              <TextBlock Text="Sensitivity" Width="62" VerticalAlignment="Center"/>
              <Slider Name="MouseCaptureSensitivitySlider"
                      Minimum="0.25"
                      Maximum="4.0"
                      Width="110"
                      Value="1.0"
                      TickFrequency="0.25"
                      IsSnapToTickEnabled="True"
                      ValueChanged="OnMouseCaptureSensitivityChanged"/>
              <TextBlock Name="MouseCaptureSensitivityValueText" Width="40" Text="1.0x" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="YM resample" VerticalAlignment="Center"/>
              <ComboBox Name="YmResampleCombo" Width="140" SelectionChanged="OnYmResampleChanged">
                <ComboBoxItem Tag="cubic">Cubic (smooth)</ComboBoxItem>
                <ComboBoxItem Tag="linear">Linear (fast)</ComboBoxItem>
              </ComboBox>
            </StackPanel>
            <Separator/>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Audio Debug" FontWeight="Bold" VerticalAlignment="Center"/>
              <CheckBox Name="AudioDebugCheck" Content="Enabled" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Audio Mix (exp)" FontWeight="Bold" Margin="0,6,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="PSG" Width="32" VerticalAlignment="Center"/>
              <Slider Name="PsgMixSlider"
                      Minimum="0"
                      Maximum="200"
                      Width="140"
                      Value="100"
                      ValueChanged="OnPsgMixChanged"/>
              <TextBlock Name="PsgMixValueText" Width="40" Text="100%" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="YM" Width="32" VerticalAlignment="Center"/>
              <Slider Name="YmMixSlider"
                      Minimum="0"
                      Maximum="200"
                      Width="140"
                      Value="100"
                      ValueChanged="OnYmMixChanged"/>
              <TextBlock Name="YmMixValueText" Width="40" Text="100%" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="Noise" Width="32" VerticalAlignment="Center"/>
              <Slider Name="NoiseMixSlider"
                      Minimum="0"
                      Maximum="200"
                      Width="140"
                      Value="100"
                      ValueChanged="OnNoiseMixChanged"/>
              <TextBlock Name="NoiseMixValueText" Width="40" Text="100%" VerticalAlignment="Center"/>
            </StackPanel>
            <Border Padding="6,4" CornerRadius="10" Background="#1A2B1E" BorderBrush="#2E5A3A" BorderThickness="1">
              <TextBox Name="AudioDebugText"
                       Classes="log-view"
                       IsReadOnly="True"
                       Background="Transparent"
                       BorderThickness="0"
                       MinHeight="54"
                       FontSize="12"
                       Foreground="#BFE9C8"
                       FontFamily="JetBrains Mono, Consolas, Menlo, monospace"
                       TextWrapping="Wrap"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       AcceptsReturn="True"/>
            </Border>
            <CheckBox Name="Pad2MirrorCheck" Content="Mirror P1 → P2" Margin="0,6,0,0"/>
            <CheckBox Name="InputTraceCheck" Content="Input Trace" Margin="0,2,0,0"/>
            <TextBlock Text="Input Debug" FontWeight="Bold" Margin="0,6,0,0"/>
            <Border Padding="6,4" CornerRadius="10" Background="#1A1E2B" BorderBrush="#2E3A5A" BorderThickness="1">
              <TextBox Name="InputDebugText"
                       Classes="log-view"
                       IsReadOnly="True"
                       Background="Transparent"
                       BorderThickness="0"
                       MinHeight="54"
                       FontSize="12"
                       Foreground="#C7D7FF"
                       FontFamily="JetBrains Mono, Consolas, Menlo, monospace"
                       TextWrapping="Wrap"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       AcceptsReturn="True"/>
            </Border>
            <Separator/>
            <TextBlock Text="Region" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock VerticalAlignment="Center" Text="Override:"/>
              <ComboBox Name="RegionOverrideCombo" Width="120" SelectionChanged="OnRegionOverrideChanged">
                <ComboBoxItem Tag="Auto">Auto</ComboBoxItem>
                <ComboBoxItem Tag="JP">JP</ComboBoxItem>
                <ComboBoxItem Tag="US">US</ComboBoxItem>
                <ComboBoxItem Tag="EU">EU</ComboBoxItem>
              </ComboBox>
            </StackPanel>
            <TextBlock x:Name="RomRegionHintText" Classes="muted" FontSize="12"/>
            <Button Content="Use ROM region" Click="OnUseRomRegion" HorizontalAlignment="Left"/>
            <Button Classes="ghost" Content="Controls..." Click="OnShowControls" HorizontalAlignment="Left"/>
            <Button Classes="ghost" Content="SNES Special ROMs..." Click="OnShowSnesSpecialRomSettings" HorizontalAlignment="Left"/>
            <Separator/>
            <TextBlock Text="ROM" FontWeight="Bold"/>
            <TextBlock Name="RomPathText" Text="(none)" TextWrapping="Wrap"/>
            <TextBlock x:Name="RomInfoText" Classes="muted" FontSize="12" TextWrapping="Wrap"/>
            <Separator/>
            <Border Classes="subpanel" Padding="10" Margin="0,2,0,0">
              <StackPanel Spacing="8">
                <StackPanel Spacing="2">
                  <TextBlock Classes="deck-label" Text="SEGA CD BAY"/>
                  <TextBlock Name="SegaCdOptionsInfo"
                             Classes="muted"
                             FontSize="11"
                             TextWrapping="Wrap"
                             Text="Boot and media overrides for the mounted Mega-CD / Sega CD disc."/>
                </StackPanel>
                <Border Classes="option-card" Padding="8,7">
                  <CheckBox Classes="option-check"
                            Name="SegaCdRamCartCheck"
                            Content="Enable RAM cartridge"
                            Checked="OnSegaCdRamCartToggle"
                            Unchecked="OnSegaCdRamCartToggle"/>
                </Border>
                <Border Classes="option-card" Padding="8,7">
                  <CheckBox Classes="option-check"
                            Name="SegaCdLoadCdToRamCheck"
                            Content="Load CD-ROM into RAM at startup"
                            Checked="OnSegaCdLoadCdToRamToggle"
                            Unchecked="OnSegaCdLoadCdToRamToggle"/>
                </Border>
                <Border Classes="option-card" Padding="8,7">
                  <CheckBox Classes="option-check"
                            Name="SegaCdForceNoDiscCheck"
                            Content="Force no disc (BIOS only)"
                            Checked="OnSegaCdForceNoDiscToggle"
                            Unchecked="OnSegaCdForceNoDiscToggle"/>
                </Border>
              </StackPanel>
            </Border>
            <Separator/>
            <TextBlock Text="PCE BIOS" FontWeight="Bold"/>
            <TextBlock Name="PceBiosPathText" Text="(auto: ./bios/syscard*.pce|.bin)" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Select BIOS…" Click="OnSelectPceBios"/>
              <Button Classes="ghost" Content="Clear" Click="OnClearPceBios"/>
            </StackPanel>
            <Separator/>
            <TextBlock Text="PSX BIOS" FontWeight="Bold"/>
            <TextBlock Name="PsxBiosPathText" Text="(none)" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Select BIOS…" Click="OnSelectPsxBios"/>
              <Button Classes="ghost" Content="Clear" Click="OnClearPsxBios"/>
            </StackPanel>
            <TextBlock Text="PSX SBI" FontWeight="Bold"/>
            <TextBlock Name="PsxSbiPathText" Text="(none)" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Select SBI…" Click="OnSelectPsxSbi"/>
              <Button Classes="ghost" Content="Clear" Click="OnClearPsxSbi"/>
            </StackPanel>
            <CheckBox Name="PsxAnalogPadCheck"
                      Content="PSX analog pad"
                      IsChecked="False"
                      Checked="OnPsxAnalogPadToggle"
                      Unchecked="OnPsxAnalogPadToggle"/>
            <CheckBox Name="PsxFastLoadCheck"
                      Content="PSX fast load"
                      IsChecked="False"
                      Checked="OnPsxFastLoadToggle"
                      Unchecked="OnPsxFastLoadToggle"/>
            <CheckBox Name="PsxSuperFastBootCheck"
                      Content="PSX superfast boot"
                      IsChecked="False"
                      Checked="OnPsxSuperFastBootToggle"
                      Unchecked="OnPsxSuperFastBootToggle"/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="PSX video" VerticalAlignment="Center"/>
              <ComboBox Name="PsxVideoStandardCombo" Width="120" SelectionChanged="OnPsxVideoStandardChanged">
                <ComboBoxItem Tag="Auto">Auto</ComboBoxItem>
                <ComboBoxItem Tag="PAL">PAL</ComboBoxItem>
                <ComboBoxItem Tag="NTSC">NTSC</ComboBoxItem>
              </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="PSX rate" VerticalAlignment="Center"/>
              <ComboBox Name="PsxFrameRateCombo" Width="120" SelectionChanged="OnPsxFrameRateChanged">
                <ComboBoxItem Tag="Auto">Auto</ComboBoxItem>
                <ComboBoxItem Tag="Hz50">50 Hz</ComboBoxItem>
                <ComboBoxItem Tag="Hz60">60 Hz</ComboBoxItem>
              </ComboBox>
            </StackPanel>
            <CheckBox Content="SMS overscan (debug)" IsChecked="False" Name="SmsOverscanCheck" Checked="OnSmsOverscanToggle" Unchecked="OnSmsOverscanToggle"/>
            <Separator/>
            <TextBlock Text="Perf" FontWeight="Bold"/>
            <TextBlock Name="FpsText" Text="FPS: -"/>
            <TextBlock Name="EmuFpsText" Text="Emu FPS: -"/>
            <TextBlock Name="FrameText" Text="Frame: -"/>
            <TextBlock Name="ResolutionText" Text="Resolution: -"/>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
              <Button Classes="compact" Content="Perf snapshot" Click="OnCapturePerfSnapshot"/>
              <TextBlock Classes="muted" FontSize="11" VerticalAlignment="Center" Text="Captures and copies current perf text"/>
            </StackPanel>
            <Border Padding="6,4" CornerRadius="10" Background="#171B25" BorderBrush="#2E3A5A" BorderThickness="1">
              <TextBox Name="PerfSnapshotText"
                       Classes="log-view"
                       IsReadOnly="True"
                       Background="Transparent"
                       BorderThickness="0"
                       MinHeight="88"
                       FontSize="12"
                       Foreground="#DCE7FF"
                       FontFamily="JetBrains Mono, Consolas, Menlo, monospace"
                       TextWrapping="NoWrap"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       AcceptsReturn="True"
                       Text="Perf snapshot idle."/>
            </Border>
            <CheckBox Content="Speed lock (real-time)" IsChecked="True" Name="SpeedLockCheck" Checked="OnSpeedLockToggle" Unchecked="OnSpeedLockToggle"/>
            <CheckBox Content="Render skip when fast" IsChecked="False" Name="RenderSkipCheck" Checked="OnRenderSkipToggle" Unchecked="OnRenderSkipToggle"/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="Speed" VerticalAlignment="Center"/>
              <Slider Name="SpeedSlider" Minimum="0.5" Maximum="2.0" Value="1.0" Width="140" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnSpeedSliderChanged"/>
              <TextBlock Name="SpeedValueText" Text="100%" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock VerticalAlignment="Center" Text="Rate:"/>
              <ComboBox Name="FrameRateCombo" SelectedIndex="0" SelectionChanged="OnFrameRateChanged">
                <ComboBoxItem Tag="Auto">Auto (detect)</ComboBoxItem>
                <ComboBoxItem Tag="Hz60">60 Hz</ComboBoxItem>
                <ComboBoxItem Tag="Hz50">50 Hz</ComboBoxItem>
              </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox Name="CpuCyclesTextBox" Width="80" Text="488"/>
              <Button Content="Set cycles/line" Click="OnApplyCpuCycles"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox Name="Z80CyclesMultTextBox" Width="80" Text="1.0"/>
              <Button Content="Set Z80 mult" Click="OnApplyZ80CyclesMult"/>
            </StackPanel>
            <Separator/>
            <TextBlock Text="Dev / Test" FontWeight="Bold"/>
            <CheckBox Content="Interlace Test Mode (448px)" IsChecked="False" Name="InterlaceTestCheck" Checked="OnInterlaceTestToggle" Unchecked="OnInterlaceTestToggle"/>
            <CheckBox Content="Static (no flicker)" IsChecked="True" Name="InterlaceStaticCheck" Checked="OnInterlaceStaticToggle" Unchecked="OnInterlaceStaticToggle" IsEnabled="False"/>
            <CheckBox Content="Sharp Pixels" IsChecked="True" Name="SharpPixelsCheck" Checked="OnSharpPixelsToggle" Unchecked="OnSharpPixelsToggle"/>
            <CheckBox Content="Advanced Pixel Filter" IsChecked="False" Name="AdvancedPixelFilterCheck" Checked="OnAdvancedPixelFilterToggle" Unchecked="OnAdvancedPixelFilterToggle"/>
            <CheckBox Content="CRT Scanlines" IsChecked="False" Name="CrtScanlinesCheck" Checked="OnCrtScanlinesToggle" Unchecked="OnCrtScanlinesToggle"/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="Scanline Strength" VerticalAlignment="Center"/>
              <Slider Name="CrtScanlineStrengthSlider"
                      Minimum="0"
                      Maximum="100"
                      Width="120"
                      Value="22"
                      ValueChanged="OnCrtScanlineStrengthChanged"/>
              <TextBlock Name="CrtScanlineStrengthText" Width="42" Text="22%" VerticalAlignment="Center"/>
            </StackPanel>
            <CheckBox Content="Force Opaque Pixels" IsChecked="False" Name="ForceOpaqueCheck"/>
            <CheckBox Content="ASCII Stream (for viewer)" IsChecked="False" Name="AsciiStreamCheck" Checked="OnAsciiStreamToggle" Unchecked="OnAsciiStreamToggle"/>
            <CheckBox Content="Preserve FB on Display Off" IsChecked="True" Name="PreserveFbCheck" Checked="OnPreserveFbToggle" Unchecked="OnPreserveFbToggle"/>
            <TextBlock Name="InterlaceTestInfo" Classes="muted" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </LayoutTransformControl>

      <Border Name="ScreenBorder"
              Grid.Row="1"
              Grid.Column="1"
              Padding="10"
              CornerRadius="8"
              Background="#081018"
              BorderBrush="{StaticResource EdStrokeBrightBrush}"
              BorderThickness="1">
        <Grid>
          <Border Background="{StaticResource EdScreenGlowBrush}" CornerRadius="6" Opacity="0.28"/>
          <Border Name="InputSurface" Background="Transparent" Focusable="True">
            <Viewbox Stretch="Uniform">
              <Grid Name="ScreenGrid" Width="320" Height="224">
                <Grid Name="ScreenSurfaceHost"
                      Width="320"
                      Height="224"/>
                <Image Name="SplashImage"
                       Source="avares://EutherDrive.UI/Assets/logo_crop.jpeg"
                       Stretch="Uniform"/>
              </Grid>
            </Viewbox>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
