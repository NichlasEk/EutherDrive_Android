<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:imaging="clr-namespace:Avalonia.Media.Imaging;assembly=Avalonia"
        xmlns:savestates="clr-namespace:EutherDrive.UI.Savestates"
        mc:Ignorable="d"
        x:Class="EutherDrive.UI.MainWindow">


  <Grid Name="RootGrid" RowDefinitions="Auto,*" ColumnDefinitions="Auto,*" Margin="12" RowSpacing="12" ColumnSpacing="12">

    <!-- Controls -->
    <StackPanel Name="TopControlsPanel" Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10">
      <Button Content="Open ROM…" Click="OnOpenRom"/>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock Text="Recent" VerticalAlignment="Center"/>
        <ComboBox Name="RecentRomCombo" Width="220" SelectionChanged="OnRecentRomSelected"/>
      </StackPanel>
      <Button Content="Start" Click="OnStart"/>
      <Button Content="Stop" Click="OnStop"/>
      <Button Content="About" Click="OnAbout"/>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock Text="Master vol" VerticalAlignment="Center"/>
        <Slider Name="MasterVolumeSlider"
                Minimum="0"
                Maximum="100"
                Width="120"
                Value="50"
                ValueChanged="OnMasterVolumeChanged"/>
        <TextBlock Name="MasterVolumeValueText" Width="36" Text="50%" VerticalAlignment="Center"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock Text="Autofire" VerticalAlignment="Center"/>
        <ToggleButton Name="AutoFireAButton" Content="A" Width="28" IsChecked="False"
                      Checked="OnAutoFireToggle" Unchecked="OnAutoFireToggle"/>
        <ToggleButton Name="AutoFireBButton" Content="B" Width="28" IsChecked="False"
                      Checked="OnAutoFireToggle" Unchecked="OnAutoFireToggle"/>
        <ToggleButton Name="AutoFireCButton" Content="C" Width="28" IsChecked="False"
                      Checked="OnAutoFireToggle" Unchecked="OnAutoFireToggle"/>
        <Slider Name="AutoFireRateSlider"
                Minimum="5"
                Maximum="30"
                Width="90"
                Value="12"
                ValueChanged="OnAutoFireRateChanged"/>
        <TextBlock Name="AutoFireRateText" Width="34" Text="12Hz" VerticalAlignment="Center"/>
      </StackPanel>
      <Border Name="SavestatePanel" Padding="6,4" BorderBrush="#2E3844" BorderThickness="1" CornerRadius="6" Background="#161B21"
              x:DataType="savestates:SavestateViewModel">
        <StackPanel Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding Slot1Label}" Width="150" FontSize="11" VerticalAlignment="Center"/>
            <Button Content="Save" Command="{Binding SaveSlot1Command}" Padding="6,2" FontSize="11"/>
            <Button Content="Load" Command="{Binding LoadSlot1Command}" Padding="6,2" FontSize="11"/>
            <Button Content="Clear" Command="{Binding ClearSlot1Command}" Padding="6,2" FontSize="11"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding Slot2Label}" Width="150" FontSize="11" VerticalAlignment="Center"/>
            <Button Content="Save" Command="{Binding SaveSlot2Command}" Padding="6,2" FontSize="11"/>
            <Button Content="Load" Command="{Binding LoadSlot2Command}" Padding="6,2" FontSize="11"/>
            <Button Content="Clear" Command="{Binding ClearSlot2Command}" Padding="6,2" FontSize="11"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding Slot3Label}" Width="150" FontSize="11" VerticalAlignment="Center"/>
            <Button Content="Save" Command="{Binding SaveSlot3Command}" Padding="6,2" FontSize="11"/>
            <Button Content="Load" Command="{Binding LoadSlot3Command}" Padding="6,2" FontSize="11"/>
            <Button Content="Clear" Command="{Binding ClearSlot3Command}" Padding="6,2" FontSize="11"/>
          </StackPanel>
        </StackPanel>
      </Border>
      <TextBlock Name="StatusText" VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Left: info (scrollable) -->
    <Border Name="InfoPanel" Grid.Row="1" Grid.Column="0" Padding="10" CornerRadius="8" Background="#181C22" BorderBrush="#2A313B" BorderThickness="1">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8" Width="240">
        <CheckBox Content="Use DummyCore" IsChecked="False" Name="UseDummyCoreCheck"/>
        <CheckBox Content="Use 6-button pad" IsChecked="False" Name="SixButtonPadCheck"/>
        <CheckBox Content="Enable audio" IsChecked="True" Name="AudioEnabledCheck" Checked="OnAudioToggle" Unchecked="OnAudioToggle"/>
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="YM resample" VerticalAlignment="Center"/>
          <ComboBox Name="YmResampleCombo" Width="140" SelectionChanged="OnYmResampleChanged">
            <ComboBoxItem Tag="cubic">Cubic (smooth)</ComboBoxItem>
            <ComboBoxItem Tag="linear">Linear (fast)</ComboBoxItem>
          </ComboBox>
        </StackPanel>
        <Separator/>
        <TextBlock Text="Audio Debug" FontWeight="Bold"/>
        <Border Padding="6,4" CornerRadius="4" Background="#1A2B1E" BorderBrush="#2E5A3A" BorderThickness="1">
          <TextBox Name="AudioDebugText"
                   IsReadOnly="True"
                   Background="Transparent"
                   BorderThickness="0"
                   FontSize="12"
                   Foreground="#BFE9C8"
                   FontFamily="JetBrains Mono, Consolas, Menlo, monospace"
                   TextWrapping="NoWrap"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled"
                   AcceptsReturn="False"/>
        </Border>
        <Separator/>
        <TextBlock Text="Region" FontWeight="Bold"/>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock VerticalAlignment="Center" Text="Override:"/>
          <ComboBox Name="RegionOverrideCombo" Width="120" SelectionChanged="OnRegionOverrideChanged">
            <ComboBoxItem Tag="Auto">Auto</ComboBoxItem>
            <ComboBoxItem Tag="JP">JP</ComboBoxItem>
            <ComboBoxItem Tag="US">US</ComboBoxItem>
            <ComboBoxItem Tag="EU">EU</ComboBoxItem>
          </ComboBox>
        </StackPanel>
        <TextBlock x:Name="RomRegionHintText" Opacity="0.85" FontSize="12"/>
        <Button Content="Use ROM region" Click="OnUseRomRegion" HorizontalAlignment="Left"/>
        <Button Content="Controls..." Click="OnShowControls" HorizontalAlignment="Left"/>
        <Separator/>
        <TextBlock Text="ROM" FontWeight="Bold"/>
        <TextBlock Name="RomPathText" Text="(none)" TextWrapping="Wrap"/>
        <TextBlock x:Name="RomInfoText" Opacity="0.85" FontSize="12" TextWrapping="Wrap"/>
        <Separator/>
        <TextBlock Text="Perf" FontWeight="Bold"/>
        <TextBlock Name="FpsText" Text="FPS: -"/>
        <TextBlock Name="EmuFpsText" Text="Emu FPS: -"/>
        <CheckBox Content="Speed lock (real-time)" IsChecked="True" Name="SpeedLockCheck" Checked="OnSpeedLockToggle" Unchecked="OnSpeedLockToggle"/>
        <CheckBox Content="Render skip when fast" IsChecked="False" Name="RenderSkipCheck" Checked="OnRenderSkipToggle" Unchecked="OnRenderSkipToggle"/>
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="Speed" VerticalAlignment="Center"/>
          <Slider Name="SpeedSlider" Minimum="0.5" Maximum="2.0" Value="1.0" Width="140" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnSpeedSliderChanged"/>
          <TextBlock Name="SpeedValueText" Text="100%" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock VerticalAlignment="Center" Text="Rate:"/>
          <ComboBox Name="FrameRateCombo" SelectedIndex="0" SelectionChanged="OnFrameRateChanged">
            <ComboBoxItem Tag="Auto">Auto (detect)</ComboBoxItem>
            <ComboBoxItem Tag="Hz60">60 Hz</ComboBoxItem>
            <ComboBoxItem Tag="Hz50">50 Hz</ComboBoxItem>
          </ComboBox>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Name="CpuCyclesTextBox" Width="80" Text="488"/>
          <Button Content="Set cycles/line" Click="OnApplyCpuCycles"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Name="Z80CyclesMultTextBox" Width="80" Text="1.0"/>
          <Button Content="Set Z80 mult" Click="OnApplyZ80CyclesMult"/>
        </StackPanel>
        <Separator/>
        <TextBlock Text="Dev / Test" FontWeight="Bold"/>
        <CheckBox Content="Interlace Test Mode (448px)" IsChecked="False" Name="InterlaceTestCheck" Checked="OnInterlaceTestToggle" Unchecked="OnInterlaceTestToggle"/>
        <CheckBox Content="Static (no flicker)" IsChecked="True" Name="InterlaceStaticCheck" Checked="OnInterlaceStaticToggle" Unchecked="OnInterlaceStaticToggle" IsEnabled="False"/>
        <CheckBox Content="Force Opaque Pixels" IsChecked="False" Name="ForceOpaqueCheck"/>
        <CheckBox Content="ASCII Stream (for viewer)" IsChecked="False" Name="AsciiStreamCheck" Checked="OnAsciiStreamToggle" Unchecked="OnAsciiStreamToggle"/>
        <CheckBox Content="Preserve FB on Display Off" IsChecked="True" Name="PreserveFbCheck" Checked="OnPreserveFbToggle" Unchecked="OnPreserveFbToggle"/>
        <TextBlock Name="InterlaceTestInfo" Opacity="0.7" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

<!-- Right: framebuffer -->
  <Border Name="ScreenBorder" Grid.Row="1" Grid.Column="1" Background="#0B0D10" BorderBrush="#1E242C" BorderThickness="1" CornerRadius="8" Padding="10">
    <Border Name="InputSurface" Background="Transparent" Focusable="True">
      <Viewbox Stretch="Uniform">
        <Grid Name="ScreenGrid" Width="320" Height="224">
          <Image Name="ScreenImage"
                 Width="320" Height="224"
                 Stretch="Fill"/>
          <Image Name="SplashImage"
                 Source="avares://EutherDrive.UI/Assets/logo_crop.jpeg"
                 Stretch="Uniform"/>
        </Grid>
      </Viewbox>
    </Border>
  </Border>





  </Grid>
</Window>
